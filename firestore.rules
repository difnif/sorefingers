// ==========================================================================
// Firestore Security Rules — sorefingers
//
// 핵심 원칙: 자기 프로젝트는 자기만 읽고 쓸 수 있다.
//
// 배포: Firebase Console → Firestore → Rules 탭에 그대로 붙여넣기 후 Publish
// ==========================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 프로젝트 — 본인 소유만 접근
    match /projects/{projectId} {
      allow read: if isOwner();
      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner()
                    && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner();

      // 하위 컬렉션 — 부모 프로젝트의 소유자만 접근
      match /nodes/{nodeId} {
        allow read, write: if isProjectOwner(projectId);
      }
      match /edges/{edgeId} {
        allow read, write: if isProjectOwner(projectId);
      }
      match /faces/{faceId} {
        allow read, write: if isProjectOwner(projectId);
      }
      match /suggestions/{suggestionId} {
        allow read, write: if isProjectOwner(projectId);
      }
      match /burnLogs/{logId} {
        allow read, write: if isProjectOwner(projectId);
      }
      match /archived/{nodeId} {
        allow read, write: if isProjectOwner(projectId);
      }
    }

    // ──── 헬퍼 함수 ────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
    }

    function isProjectOwner(projectId) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }
  }
}
